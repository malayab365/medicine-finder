# Copy to .env and fill in. Do not commit .env.

# Required for symptom search (M3+). Not needed for name search.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openrouter/auto

# User accounts / sessions (symptom search is gated behind login).
# Generate a strong secret, e.g.  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Optional overrides
# DATABASE_PATH=medicine_search.db
# OPENFDA_BASE_URL=https://api.fda.gov
# RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST
# LOG_LEVEL=INFO
